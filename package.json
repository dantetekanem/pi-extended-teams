{
  "name": "pi-extended-teams",
  "version": "1.0.0",
  "description": "tmux-only, self-managing, role-aware agent teams for pi", 
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantetekanem/pi-extended-teams.git"
  },
  "author": "dantetekanem",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "ai-agent",
    "multi-agent",
    "agent-teams",
    "agent-coordination",
    "autonomous-agents",
    "task-management",
    "team-collaboration",
    "agent-orchestration",
    "coding-assistant",
    "tmux"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:focused": "vitest run src/utils/claims.test.ts src/utils/tasks.test.ts src/utils/model-resolution.test.ts src/utils/settings.test.ts src/utils/write-queue.test.ts src/utils/shared-memory.test.ts extensions/index.test.ts",
    "build": "tsc --noEmit"
  },
  "main": "extensions/index.ts",
  "files": [
    "extensions",
    "skills",
    "src",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "uuid": "^11.1.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "image": "https://raw.githubusercontent.com/dantetekanem/pi-extended-teams/main/pi-team-in-action.png",
    "extensions": [
      "extensions/index.ts"
    ],
    "skills": [
      "skills"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
